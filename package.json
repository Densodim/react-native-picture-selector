{
  "name": "react-native-picture-selector",
  "version": "1.0.16",
  "description": "High-performance photo/video picker for React Native using Nitro Modules",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "nitrogen",
    "nitro.json",
    "*.podspec"
  ],
  "scripts": {
    "generate": "nitrogen src/specs",
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "prepack": "bob build"
  },
  "keywords": [
    "react-native",
    "photo",
    "video",
    "picker",
    "nitro",
    "ios",
    "android",
    "camera",
    "gallery"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "react-native-nitro-modules": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "nitrogen": "latest",
    "react-native-builder-bob": "^0.30.0",
    "react-native-nitro-modules": ">=0.20.0",
    "typescript": "^5.3.0"
  },
  "nitro": {
    "ios": {
      "iosModuleName": "NitroPictureSelector"
    },
    "android": {
      "androidNamespace": "com.nitro.pictureselector",
      "androidCxxLibName": "NitroPictureSelector"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
